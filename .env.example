# Optional override — leave unset to use Vercel Supabase POSTGRES_* vars
# DATABASE_URL=

# Injected by Vercel ↔ Supabase integration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=

# Supabase client (not used by this app yet — Drizzle uses POSTGRES_* above)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IGDB (Twitch developer app)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Cron routes in production (Authorization: Bearer <secret>)
CRON_SECRET=

# Cron orchestrator (npm run cron) — defaults to http://localhost:3000
# CRON_BASE_URL=https://your-app.vercel.app

# PSN scraper (defaults: de-DE / de-de)
PSN_LOCALE=de-DE
PSN_STORE_PATH=de-de

# Optional
USD_TO_EUR_RATE=0.92
