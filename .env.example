# Optional override — leave unset to use Vercel Supabase POSTGRES_* vars
# DATABASE_URL=

# Injected by Vercel ↔ Supabase integration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=

# Supabase Auth (browser + SSR) — same project as POSTGRES_*
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional aliases / server-only
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # wishlist alerts (lookup auth emails)

# IGDB (Twitch developer app)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# Optional overrides for external_games source ids (defaults work for most setups)
# IGDB_PSN_EXTERNAL_GAME_SOURCE=36
# IGDB_XBOX_EXTERNAL_GAME_SOURCE=11

# Cron routes in production (Authorization: Bearer <secret>)
CRON_SECRET=

# Cron: pnpm cron → remote sources against CRON_BASE_URL (production)
#       pnpm cron-local → CheapShark against http://localhost:3000 (needs pnpm dev)
# CRON_BASE_URL=https://your-app.vercel.app

# PSN scraper (defaults: de-DE / de-de)
PSN_LOCALE=de-DE
PSN_STORE_PATH=de-de
# Optional overrides
# PSN_REGION=DE
# PSN_DEALS_CATEGORY_ID=
# PSN_GRAPHQL_HASH=

# Xbox catalog (defaults: de-DE / DE)
# XBOX_LOCALE=de-DE
# XBOX_MARKET=DE

# Optional
USD_TO_EUR_RATE=0.92

# Public site URL (links in wishlist alert emails)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Wishlist deal alerts (Resend) — no-op if unset
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Broke Gamer <alerts@yourdomain.com>
