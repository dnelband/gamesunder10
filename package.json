{
  "name": "gamesunder10",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "node scripts/db-reset.mjs",
    "cron": "node scripts/cron-orchestrator.mjs",
    "cron-local": "node scripts/cron-orchestrator.mjs --local --verbose",
    "cron-local:quiet": "node scripts/cron-orchestrator.mjs --local",
    "cron:local-once": "bash scripts/run-local-cron.sh",
    "test": "tsx --test $(find lib -name '*.test.ts' | sort)",
    "smoke:store-urls": "npx tsx --env-file=.env.local scripts/smoke-store-urls.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
